[Unit]
Description=dserv-agent mesh registry
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/dserv-agent --server --landing-page --listen :443 --ess-registry /usr/local/dserv/db/ess.db --backup-interval 12h --workgroup brown-sheinberg
Restart=always
RestartSec=5

# GITHUB_TOKEN lives here (root-only file, chmod 600) so the registry can
# authenticate to the GitHub API (5000 req/hr vs 60) when caching releases.
EnvironmentFile=-/etc/dserv-agent/env

[Install]
WantedBy=multi-user.target
