/*
 * extio-zephyr devicetree overlay for the FRDM-RW612.
 *
 * Enable ctimer1 as the hardware pulse timer for box_gpio's non-blocking,
 * box-timed DO pulses (ctimer0 is already claimed by the board). The Zephyr
 * counter driver (nxp,lpc-ctimer) binds to it, giving us up to 4 match channels
 * of µs-precision, CPU-free pulse timing -- the RW612 analog of the RP2350
 * alarm pool.
 */
/ {
	aliases {
		box-gpio-port     = &hsgpio0;   /* box pin n -> hsgpio0.n (12 = user LED) */
		box-pulse-counter = &ctimer1;   /* hardware box-timed pulse               */
	};
};

&ctimer1 {
	status = "okay";
};

/*
 * Enable the ENET IEEE-1588 hardware clock (block #5). The board enables the MAC
 * and MDIO but leaves this node disabled; turning it on instantiates the PTP
 * clock device (PTP_CLOCK_NXP_ENET), the sub-µs sync enabler.
 */
&enet_ptp_clock {
	status = "okay";
};

/*
 * Two USB CDC-ACM instances on the HS device controller (block #4):
 *   cdc_acm_data    -- the binary 128-byte dserv frame pipe (data + config)
 *   cdc_acm_console -- the human text console / bootstrap CLI
 * This is the "config alongside the data pump" split: both channels are the same
 * USB primitive, differentiated by role. The frame pipe can later move to raw
 * vendor bulk endpoints without touching the box logic (see BENCH_NXP.md D1/D2).
 */
&zephyr_udc0 {
	cdc_acm_data: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
	cdc_acm_console: cdc_acm_uart1 {
		compatible = "zephyr,cdc-acm-uart";
	};
};
