+++ b/src/rp2_common/pico_btstack/btstack_flash_bank.c
@@ -10,6 +10,27 @@
 #include "hardware/flash.h"
 #include <string.h>
 
+/* ---- dserv extio DIAG+FIX (local patch; wiznet-io/BLE.md "slot-boot radio
+ * wedge" 2026-07-17). The TLV banks live at a PHYSICAL top-of-flash offset,
+ * but the reads below went through the ATRANS-TRANSLATED XIP window -- correct
+ * on a flat boot (identity mapping), garbage under an A/B partition boot
+ * (bootrom remaps the windows onto the booted slot). Garbage reads make both
+ * banks look invalid and btstack's format-verify churn never converges ->
+ * watchdog. Fix: address the banks via the untranslated physical alias, which
+ * is mapping-independent (same bytes on a flat boot). Same failure family as
+ * the pico_flash.h persist-aperture bug, one library deeper. */
+#ifdef XIP_NOCACHE_NOALLOC_NOTRANSLATE_BASE
+#define PICO_FLASH_BANK_XIP_READ_BASE XIP_NOCACHE_NOALLOC_NOTRANSLATE_BASE
+#else
+#define PICO_FLASH_BANK_XIP_READ_BASE XIP_BASE   /* RP2040: no ATRANS, no alias */
+#endif
+#ifdef BOX_BLE_BREADCRUMBS
+#include "hardware/structs/watchdog.h"
+#define BBC(x) (watchdog_hw->scratch[0] = (uint32_t)(x))   /* scratch[0]: [2]/[3] hold rom_reboot params! */
+#else
+#define BBC(x) ((void)0)
+#endif
+
 // Check sizes
 static_assert(PICO_FLASH_BANK_TOTAL_SIZE % (FLASH_SECTOR_SIZE * 2) == 0, "PICO_FLASH_BANK_TOTAL_SIZE invalid");
 static_assert(PICO_FLASH_BANK_TOTAL_SIZE <= PICO_FLASH_SIZE_BYTES, "PICO_FLASH_BANK_TOTAL_SIZE too big");
@@ -66,6 +87,7 @@ extern uint32_t pico_flash_bank_get_storage_offset_func(void);
 static void pico_flash_bank_erase(void * context, int bank) {
     (void)(context);
     DEBUG_PRINT("erase: bank %d\n", bank);
+    BBC(0x74u + (uint32_t)bank);
     mutation_operation_t mop = {
             .op_is_erase = true,
             .p0 = pico_flash_bank_get_storage_offset_func() + (PICO_FLASH_BANK_SIZE * bank),
@@ -89,8 +111,9 @@ static void pico_flash_bank_read(void *context, int bank, uint32_t offset, uint8
     assert((offset + size) <= PICO_FLASH_BANK_SIZE);
     if ((offset + size) > PICO_FLASH_BANK_SIZE) return;
 
-    // Flash is xip
-    memcpy(buffer, (void *)(XIP_BASE + pico_flash_bank_get_storage_offset_func() + (PICO_FLASH_BANK_SIZE * bank) + offset), size);
+    // Flash is xip (read via the untranslated alias: the offset is PHYSICAL)
+    BBC(0x70u + (uint32_t)bank);
+    memcpy(buffer, (void *)(PICO_FLASH_BANK_XIP_READ_BASE + pico_flash_bank_get_storage_offset_func() + (PICO_FLASH_BANK_SIZE * bank) + offset), size);
 }
 
 static void pico_flash_bank_write(void * context, int bank, uint32_t offset, const uint8_t *data, uint32_t size) {
@@ -131,14 +154,14 @@ static void pico_flash_bank_write(void * context, int bank, uint32_t offset, con
         // Copy data we're not going to overwrite in the first page
         if (page == first_page && offset > 0) {
             memcpy(page_data,
-                (void *)(XIP_BASE + bank_start_pos + (page * FLASH_PAGE_SIZE)),
+                (void *)(PICO_FLASH_BANK_XIP_READ_BASE + bank_start_pos + (page * FLASH_PAGE_SIZE)),
                 offset);
         }
 
         // Copy the data we're not going to overwrite in the last page
         if (page == last_page - 1 && (offset + size_left) < FLASH_PAGE_SIZE) {
             memcpy(page_data + offset + size_left,
-                (void *)(XIP_BASE + bank_start_pos + (page * FLASH_PAGE_SIZE) + offset + size_left),
+                (void *)(PICO_FLASH_BANK_XIP_READ_BASE + bank_start_pos + (page * FLASH_PAGE_SIZE) + offset + size_left),
                 FLASH_PAGE_SIZE - offset - size_left);
         }
 
